{
"name": "mon-premier-projet",
"version": "0.0.0",
"scripts": {
"ng": "ng",
"start": "ng serve",
"build": "ng build",
"watch": "ng build --watch --configuration development",
"test": "ng test",
"start:local": "npm run gs-api && ng serve -- --proxyConfig=proxy.conf.json",
"gs-api:clean": "rimraf src/gs-api",
"gs-api:create-folders": "shx mkdir -p tools/swagger/src",
"gs-api:download": "curl http://localhost:8081/v3/api-docs -o ./tools/swagger/src/swagger.json",
"gs-api:swagger-gen": "openapi-generator-cli generate -i ./tools/swagger/src/swagger.json -g typescript-angular -p ngVersion=13 -o src/gs-api/src --skip-validate-spec",
"gs-api": "npm run gs-api:clean && npm run gs-api:create-folders && npm run gs-api:download && npm run gs-api:swagger-gen",
"gs-api:full": "npm run gs-api"
},

  "private": true,
  "dependencies": {
    "@angular/animations": "~13.0.0-next.0",
    "@angular/cdk": "^13.3.9",
